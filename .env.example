# ── Mode ──────────────────────────────────────────────────────────────────────
# Set USE_SQLITE=true for local development (no MySQL needed).
# Set USE_SQLITE=false (or omit) for production MySQL.
USE_SQLITE=true
SQLITE_PATH=dev/conapesca_dev.sqlite

# ── MySQL (production) ────────────────────────────────────────────────────────
# Fill these when deploying against the real server.
# Alternatively, set DATABASE_URL=mysql://user:pass@host:3306/dbname
CONAPESCA_DB_HOST=CHANGEME
CONAPESCA_DB_PORT=3306
CONAPESCA_DB_USER=CHANGEME
CONAPESCA_DB_PASSWORD=CHANGEME
CONAPESCA_DB_NAME=CHANGEME

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
MCP_BASE_PATH=/mcp
LOG_LEVEL=INFO
